{
  "daemon": {
    "name": "Atheon Scanner Daemon",
    "version": "1.0.0",
    "log_level": "INFO",
    "status_file": "/tmp/atheon_daemon_status.json"
  },
  "repositories": {
    "atheon-scanner": {
      "path": "/nas/Temp/repos/Atheon-Scanner",
      "name": "Atheon-Scanner",
      "role": "scanner",
      "auto_commit": true,
      "branch": "master"
    },
    "atheon-enhanced": {
      "path": "/nas/Temp/repos/Atheon-Enhanced",
      "name": "Atheon-Enhanced",
      "role": "scanner-core",
      "auto_commit": true,
      "branch": "master"
    },
    "atheon-benchmark": {
      "path": "/nas/Temp/repos/Atheon-Benchmark",
      "name": "Atheon-Benchmark",
      "role": "benchmark",
      "auto_commit": false,
      "branch": "master"
    }
  },
  "scanning": {
    "daily_target": 100,
    "max_repos": 1000,
    "batch_size": 50,
    "rate_limit_delay": 2,
    "languages": [
      "javascript",
      "python",
      "go",
      "rust",
      "java",
      "typescript",
      "c++",
      "ruby"
    ],
    "min_stars": 1000,
    "updated_since": "2024-01-01"
  },
  "scheduling": {
    "daily_scan_time": "02:00",
    "continuous_improvement_interval": 6,
    "benchmark_interval": 24,
    "documentation_update_interval": 24,
    "timezone": "UTC"
  },
  "patterns": {
    "occurrence_threshold": 10,
    "priority_thresholds": {
      "critical": 50,
      "high": 30,
      "medium": 10,
      "low": 5
    },
    "auto_add_enabled": true,
    "categories": {
      "injection": ["sql", "command", "ldap", "xpath"],
      "web-security": ["xss", "csrf", "ssrf"],
      "secrets": ["credential", "key", "token", "password"],
      "cryptography": ["crypto", "hash", "encryption"],
      "general-security": ["injection", "overflow", "underflow"]
    }
  },
  "automation": {
    "auto_commit": true,
    "commit_message_template": "feat: Auto-add {pattern_count} security patterns\n\n## Automated Pattern Addition\n- Source: Atheon Scanner\n- Generated: {timestamp}\n- Repositories: {repo_count}\n\nAuto-generated by Atheon daemon runner.",
    "push_immediately": true,
    "create_pull_requests": false,
    "max_auto_commits_per_day": 10
  },
  "improvement": {
    "enabled": true,
    "min_confidence_score": 0.8,
    "optimization_iterations": 3,
    "benchmark_threshold": 80,
    "learning_rate": 0.1,
    "adaptation_enabled": true
  },
  "monitoring": {
    "log_retention_days": 30,
    "metrics_enabled": true,
    "alert_thresholds": {
      "scan_failure_rate": 0.1,
      "pattern_addition_failure_rate": 0.05,
      "benchmark_score_decline": 10
    },
    "health_check_interval": 300,
    "performance_tracking": true
  },
  "integration": {
    "github_token_env": "GITHUB_TOKEN",
    "api_timeout": 30,
    "max_retries": 3,
    "retry_delay": 5,
    "webhook_enabled": false,
    "webhook_url": ""
  },
  "experimental": {
    "ml_pattern_detection": false,
    "cross_repo_learning": true,
    "automated_testing": true,
    "performance_profiling": false,
    "adaptive_scheduling": false
  }
}